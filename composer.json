{
  "name": "appnave/nave-sdk-iss",
  "description": "This package is used to communicate with the permission and authentication microservice.",
  "type": "library",
  "keywords": [
    "appnave",
    "laravel",
    "hub",
    "nave-sdk-iss"
  ],
  "homepage": "https://github.com/appnave/nave-sdk-iss",
  "license": "MIT",
  "authors": [
    {
      "name": "App Nave",
      "email": "contato@nave.app.br",
      "role": "Owner"
    }
  ],
  "require": {
    "php": "^8.0|^8.1|^8.2|^8.3",
    "ably/ably-php": "^1.1",
    "illuminate/contracts": "^8.0|^9.0|^10.0|^11.0|^12.0",
    "spatie/laravel-permission": "^4.0|^5.0|^6.0"
  },
  "require-dev": {
    "laravel/pint": "^1.13",
    "phpunit/phpunit": "^9.0|^10.0"
  },
  "autoload": {
    "psr-4": {
      "BildVitta\\Hub\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BildVitta\\Hub\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "laravel": {
      "providers": [
        "BildVitta\\Hub\\HubServiceProvider"
      ],
      "aliases": {
        "hub": "BildVitta\\Hub\\Facades\\Hub"
      }
    }
  },
  "prefer-stable": true,
  "minimum-stability": "dev",
  "scripts": {
    "check-style": [
      "vendor/bin/pint --test"
    ],
    "fix-style": [
      "vendor/bin/pint"
    ]
  }
}